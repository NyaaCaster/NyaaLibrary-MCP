# ============================================================
# NyaaLibrary-MCP — 环境配置模板
# 复制为 .env 并填写真实值（.env 已被 .gitignore 排除）。
# ============================================================

# --- HTTP 服务 ---
APP_PORT=5101
HOST=0.0.0.0

# --- MCP 鉴权（Authorization: Bearer <key>）---
# 生成示例：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MCP_API_KEY=

# --- 前端管理登录（账号密码唯一）---
AUTH_USERNAME=admin
AUTH_PASSWORD=
AUTH_SECRET=
AUTH_TOKEN_TTL_HOURS=720

# --- 文档上传 ---
MAX_FILE_SIZE_MB=128
MAX_UPLOAD_COUNT=10

# --- 分块设置 ---
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# --- 批处理设置 ---
BATCH_SIZE=32
CONCURRENCY_LIMIT=3
MAX_RETRIES=3

# --- 检索设置 ---
RETRIEVAL_TOP_K=5
DENSE_TOP_K=50
SPARSE_TOP_K=50

# --- 嵌入模型（OpenAI 兼容 /embeddings；留空可在前端配置）---
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=
EMBEDDING_DIM=

# --- 本体记忆 REST 端点成对鉴权（决策10/F4）---
# 调用端 KB_CLIENT_TOKEN 须与此相等
KB_SERVER_TOKEN=

# --- 数据与时区 ---
# DATA_DIR 默认 <repo>/data；容器内由 docker-compose 设为 /app/data。
TZ=Asia/Shanghai
